{
  "name": "bayaran-madrasah-backend",
  "version": "1.0.0",
  "description": "Backend System Aplikasi Bayaran Madrasah - Bun, Elysia.js, Drizzle ORM, PostgreSQL, Redis",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "db:push": "bunx drizzle-kit push",
    "db:studio": "bunx drizzle-kit studio",
    "db:seed": "bun src/db/seed.ts"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.1.1",
    "@elysiajs/jwt": "^1.1.1",
    "@elysiajs/swagger": "^1.1.5",
    "bcryptjs": "^2.4.3",
    "drizzle-orm": "^0.38.3",
    "elysia": "^1.1.25",
    "ioredis": "^5.4.2",
    "postgres": "^3.4.5",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/bun": "latest",
    "drizzle-kit": "^0.30.1"
  }
}
