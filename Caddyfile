# Konfigurasi Caddy untuk local testing
localhost {
    # Rute ke API Backend
    handle /api/* {
        reverse_proxy backend:3000
    }

    # Rute sisanya dilempar ke Frontend Nginx Container
    handle {
        reverse_proxy frontend:80
    }

    # Caddy akan otomatis mengurus pembuatan sertifikat SSL (HTTPS) dari Let's Encrypt!
}
